# Resource governance
RESOURCE_CEILING=0.90
RESOURCE_SOFT=0.80
RESOURCE_SAMPLE_INTERVAL=1.0

# Server
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# Model paths (set these after running setup_models.py)
STT_MODEL=large-v3-turbo
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
TTS_MODEL=en_US-lessac-medium

# Ollama
OLLAMA_HOST=http://localhost:11434

# Database
DATABASE_PATH=./data/english_coach.db

# Audio storage
AUDIO_STORAGE_PATH=./data/audio
